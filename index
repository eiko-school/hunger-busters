// ===== STATE =====
const G={turn:1,countries:{},wb:{},sel:[],log:[],countryLogs:{},evTab:'plus',curEv:null};
let cRole=null;

// ===== HELPERS =====
const food=d=>d.farm+d.fish+d.livestock+d.trade;
const isHungry=n=>{const d=G.countries[n];return d&&d.pop>food(d);};
const gd=n=>n==='世界銀行'?G.wb:G.countries[n];
const $=id=>document.getElementById(id);
function show(id){$(id).classList.remove('hidden');}
function hide(id){$(id).classList.add('hidden');}

// ===== SETUP =====
function setupGame(){
  const s1=$('sel1').value,s2=$('sel2').value,s3=$('sel3').value;
  if(new Set([s1,s2,s3]).size<3){alert('3か国は異なる国を選んでください。');return;}
  G.sel=[s1,s2,s3];
  G.countries={};G.sel.forEach(n=>{G.countries[n]={...INIT[n]};});
  G.wb={...WB_INIT};G.turn=1;G.log=[];
  G.countryLogs={};G.sel.forEach(n=>{G.countryLogs[n]=[];});
  addLog('ゲーム開始',`参加国: ${G.sel.join(', ')} + 世界銀行`,'sys');
  hide('lobbyScreen');show('roleScreen');buildRoles();
}

const FLAGS={'日本':'🇯🇵','アメリカ':'🇺🇸','インド':'🇮🇳','カナダ':'🇨🇦','イギリス':'🇬🇧',
  'エジプト':'🇪🇬','アルゼンチン':'🇦🇷','ブラジル':'🇧🇷','オーストラリア':'🇦🇺','ベトナム':'🇻🇳'};

function buildRoles(){
  const g=$('roleGrid');g.innerHTML='';
  [...G.sel,'世界銀行'].forEach(r=>{
    const isWB=r==='世界銀行';
    const d=document.createElement('div');
    d.className='role-card'+(isWB?' wb':'');
    d.innerHTML=`<div class="ico">${isWB?'🏦':FLAGS[r]||'🌍'}</div>
      <div class="rn">${r}</div>
      <div class="rd">${isWB?'全国情報を把握・イベント操作':'自国の状況のみ閲覧'}</div>`;
    d.onclick=()=>enterRole(r);
    g.appendChild(d);
  });
}

function enterRole(role){
  hide('roleScreen');
  if(role==='世界銀行'){show('wbScreen');renderWB();}
  else{cRole=role;show('countryScreen');renderCountry();}
}

function backToRole(){
  hide('countryScreen');hide('wbScreen');show('roleScreen');buildRoles();
}

// ===== COUNTRY =====
function renderCountry(){
  const d=G.countries[cRole];
  $('cTurn').textContent=`ターン ${G.turn}`;
  $('cName').textContent=cRole;
  const hungry=isHungry(cRole);
  $('cPill').innerHTML=`<div class="pill ${hungry?'danger':'safe'}">${hungry?'⚠ 飢餓発生中':'✓ 安全'}</div>`;
  const toks=[
    {ico:'👥',lbl:'人口',key:'pop',cls:'pop'},
    {ico:'🌾',lbl:'農業',key:'farm',cls:'farm'},
    {ico:'🐟',lbl:'漁業',key:'fish',cls:'fish'},
    {ico:'🐄',lbl:'畜産',key:'livestock',cls:'live'},
    {ico:'🚢',lbl:'貿易',key:'trade',cls:'trade'},
  ];
  $('cTokRows').innerHTML=toks.map(t=>`<div class="tok-row">
    <span class="t-ico">${t.ico}</span><span class="t-lbl">${t.lbl}</span>
    <span class="t-val ${t.cls}">${d[t.key]}</span>
    <div class="t-adjs">
      <button class="adj m" onclick="cAdj('${t.key}',-1)">－</button>
      <button class="adj m" onclick="cAdj('${t.key}',-5)">-5</button>
