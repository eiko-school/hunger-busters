function populateSels(){
  ['mTo','tTo','tradeSeller','tradeBuyer'].forEach(id=>{
    const s=$(id);if(!s)return;
    s.innerHTML=G.sel.map(n=>`<option value="${n}">${n}</option>`).join('');
  });
  if($('tradeBuyer'))$('tradeBuyer').selectedIndex=1;
}
function openMM(){$('moneyModal').classList.add('open');}
function closeMM(){$('moneyModal').classList.remove('open');}
function openTM(){$('tokenModal').classList.add('open');}
function closeTM(){$('tokenModal').classList.remove('open');}

function doMM(){
  const to=$('mTo').value,amt=parseInt($('mAmt').value)||0;
  if(amt<=0)return;
  if(G.wb.money<amt){alert('世界銀行の資金が不足しています。');return;}
  G.wb.money-=amt;G.countries[to].money+=amt;
  addLog('資金援助',`世界銀行 → ${to}: ${amt.toLocaleString()}円`,'sys');
  closeMM();renderWB();
}
function doTM(){
  const to=$('tTo').value,type=$('tType').value,amt=parseInt($('tAmt').value)||0;
  if(amt<=0)return;
  const nm={farm:'農業',fish:'漁業',livestock:'畜産',trade:'貿易',pop:'人口'};
  if((G.wb[type]||0)<amt){alert('世界銀行のトークンが不足しています。');return;}
  G.wb[type]-=amt;G.countries[to][type]=(G.countries[to][type]||0)+amt;
  addLog('トークン援助',`世界銀行 → ${to}: ${nm[type]}トークン ${amt}個`,'sys');
  closeTM();renderWB();
}

// ===== TRADE =====
function openTrade(){
  // populate selects
  ['tradeSeller','tradeBuyer'].forEach(id=>{
    const s=$(id);
    s.innerHTML=G.sel.map(n=>`<option value="${n}">${n}</option>`).join('');
  });
  $('tradeBuyer').selectedIndex=1;
  updateTradePreview();
  // live preview on change
  ['tradeSeller','tradeBuyer','tradeTokenType','tradeTokenAmt','tradePrice'].forEach(id=>{
    $(id).oninput=updateTradePreview;
    $(id).onchange=updateTradePreview;
  });
  $('tradeModal').classList.add('open');
}
function closeTrade(){$('tradeModal').classList.remove('open');}

function updateTradePreview(){
  const seller=$('tradeSeller').value;
  const buyer=$('tradeBuyer').value;
  const tokType=$('tradeTokenType').value;
  const tokAmt=parseInt($('tradeTokenAmt').value)||0;
  const price=parseInt($('tradePrice').value)||0;
  const NAMES={farm:'農業',fish:'漁業',livestock:'畜産',trade:'貿易'};
  const ICONS={farm:'🌾',fish:'🐟',livestock:'🐄',trade:'🚢'};
  const sellerD=G.countries[seller];
  const buyerD=G.countries[buyer];
  if(!sellerD||!buyerD||seller===buyer){
    $('tradePreview').innerHTML=`<div style="color:var(--red);font-size:.78rem;text-align:center">売り手と買い手は異なる国を選んでください</div>`;
    return;
  }
  const sellerHasEnough=sellerD[tokType]>=tokAmt;
  const buyerHasEnough=buyerD.money>=price;
  $('tradePreview').innerHTML=`
    <div style="background:rgba(74,179,232,.07);border:1px solid rgba(74,179,232,.3);border-radius:10px;padding:13px 15px">
      <div style="font-size:.7rem;color:var(--muted);letter-spacing:1px;margin-bottom:10px">📋 取引内容プレビュー</div>
      <div style="display:flex;flex-direction:column;gap:7px">
        <div style="display:flex;align-items:center;justify-content:space-between;font-size:.82rem">
          <span style="color:var(--muted)">${seller}</span>
          <span style="color:${sellerHasEnough?'#4ab3e8':'var(--red)'}">
            ${ICONS[tokType]}${NAMES[tokType]} <strong>${tokAmt}個</strong> 譲渡
            ${!sellerHasEnough?`<span style="color:var(--red);font-size:.7rem">（不足！現在${sellerD[tokType]}個）</span>`:''}
          </span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;font-size:.82rem">
          <span style="color:var(--muted)">${buyer}</span>
          <span style="color:${buyerHasEnough?'var(--accent)':'var(--red)'}">
            💴 <strong>${price.toLocaleString()}円</strong> 支払い
            ${!buyerHasEnough?`<span style="color:var(--red);font-size:.7rem">（不足！現在${buyerD.money.toLocaleString()}円）</span>`:''}
          </span>
        </div>
        ${price===0?`<div style="font-size:.7rem;color:var(--muted);text-align:center">※ 無償譲渡</div>`:''}
      </div>
    </div>`;
}

function doTrade(){
  const seller=$('tradeSeller').value;
  const buyer=$('tradeBuyer').value;
  const tokType=$('tradeTokenType').value;
  const tokAmt=parseInt($('tradeTokenAmt').value)||0;
  const price=parseInt($('tradePrice').value)||0;
  const NAMES={farm:'農業',fish:'漁業',livestock:'畜産',trade:'貿易'};
  const ICONS={farm:'🌾',fish:'🐟',livestock:'🐄',trade:'🚢'};

  if(seller===buyer){alert('売り手と買い手は異なる国を選んでください。');return;}
  if(tokAmt<=0){alert('取引数量を入力してください。');return;}

  const sellerD=G.countries[seller];
  const buyerD=G.countries[buyer];
  if(sellerD[tokType]<tokAmt){alert(`${seller}の${NAMES[tokType]}トークンが不足しています。\n現在: ${sellerD[tokType]}個`);return;}
  if(price>0&&buyerD.money<price){alert(`${buyer}の資金が不足しています。\n現在: ${buyerD.money.toLocaleString()}円`);return;}

  // apply
  sellerD[tokType]-=tokAmt;
  buyerD[tokType]=(buyerD[tokType]||0)+tokAmt;
  if(price>0){buyerD.money-=price;sellerD.money+=price;}

  // build announce
  const priceText=price>0?`${price.toLocaleString()}円`:'無償';
  const html=`
    <div style="background:var(--surface);border:1px solid rgba(74,179,232,.4);border-radius:10px;padding:14px 16px;margin-bottom:12px">
      <div style="font-size:.7rem;color:var(--muted);margin-bottom:8px;letter-spacing:1px">取引概要</div>
      <div style="font-weight:700;font-size:.95rem;color:#4ab3e8;text-align:center">
        ${seller} → ${buyer}
      </div>
      <div style="text-align:center;font-size:.8rem;color:var(--muted);margin-top:4px">
        ${ICONS[tokType]}${NAMES[tokType]}トークン ${tokAmt}個 ／ ${priceText}
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px 14px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:2px;margin-bottom:7px">${seller}（売り手）</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          <span style="background:var(--surface);border:1px solid var(--red);color:var(--red);padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:700">${ICONS[tokType]}${NAMES[tokType]} −${tokAmt}</span>
          ${price>0?`<span style="background:var(--surface);border:1px solid var(--green);color:var(--green);padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:700">💴 +${price.toLocaleString()}円</span>`:''}
        </div>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px 14px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:2px;margin-bottom:7px">${buyer}（買い手）</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          <span style="background:var(--surface);border:1px solid var(--green);color:var(--green);padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:700">${ICONS[tokType]}${NAMES[tokType]} +${tokAmt}</span>
          ${price>0?`<span style="background:var(--surface);border:1px solid var(--red);color:var(--red);padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:700">💴 −${price.toLocaleString()}円</span>`:''}
        </div>
      </div>
    </div>`;

  $('tradeAnnounceContent').innerHTML=html;
  addLog('国間取引',`${seller} → ${buyer}: ${NAMES[tokType]}トークン ${tokAmt}個 ／ ${priceText}`,'sys');
  // 各国ログに記録
  const tradeTitle=`${seller} → ${buyer} 取引`;
  const selChanges=[{key:tokType,delta:-tokAmt}];
  const buyChanges=[{key:tokType,delta:tokAmt}];
  if(price>0){selChanges.push({key:'money',delta:price});buyChanges.push({key:'money',delta:-price});}
  addCLog(seller,{type:'trade',title:tradeTitle,changes:selChanges});
  addCLog(buyer, {type:'trade',title:tradeTitle,changes:buyChanges});
  closeTrade();
  $('tradeAnnounceModal').classList.add('open');
  renderWB();
}

// ===== TURN / LOG =====
function changeTurn(d){
  G.turn=Math.max(1,G.turn+d);
  if(d>0)addLog(`ターン${G.turn}`,'ターンが進みました','sys');
  renderWB();
}
function addLog(title,msg,type){
  G.log.unshift({turn:G.turn,title,msg,type,time:new Date().toLocaleTimeString('ja-JP')});
  renderLog();
}
function renderLog(){
  const el=$('logEl');if(!el)return;
  if(!G.log.length){el.innerHTML='<span style="color:var(--muted)">まだ記録はありません。</span>';return;}
  el.innerHTML=G.log.slice(0,60).map(e=>
    `<div class="le ${e.type==='plus'?'pl':e.type==='minus'?'mi':'sy'}">
      <span class="tt">T${e.turn}</span><span style="color:var(--muted);margin-right:5px">${e.time}</span>
      <span class="et">[${e.title}]</span> ${e.msg}
    </div>`).join('');
}
function clearLog(){G.log=[];renderLog();}
</script>
</body>
</html>
