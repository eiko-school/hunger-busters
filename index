      <div class="ov-body">
        ${tRows.map(t=>`<div class="ov-tr">
          <span class="ico">${t.ico}</span><span class="lbl">${t.lbl}</span>
          <span class="vl ${t.cls}">${d[t.key]}</span>
          <div class="oa">
            <button class="adj m" onclick="wAdj('${name}','${t.key}',-1)">－</button>
            <button class="adj p" onclick="wAdj('${name}','${t.key}',1)">＋</button>
