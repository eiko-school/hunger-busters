      <button class="adj p" onclick="cAdj('${t.key}',1)">＋</button>
    </div></div>`).join('');
  const f=food(d),pct=d.pop===0?100:Math.min(100,Math.round(f/d.pop*100)),diff=f-d.pop;
  $('cFoodBar').innerHTML=`
    <div class="fb-row"><span class="lbl">🌽 食料合計</span><span class="val ${hungry?'danger':'safe'}">${f}</span></div>
    <div class="fb-row"><span class="lbl">👥 人口</span><span class="val">${d.pop}</span></div>
    <div class="prog-wrap" style="margin:8px 0"><div class="prog-fill ${hungry?'danger':'safe'}" style="width:${pct}%"></div></div>
    <div style="font-size:.73rem;color:${hungry?'var(--red)':'var(--green)'};text-align:right;font-weight:700">
      ${diff>=0?'余剰':'不足'}: ${Math.abs(diff)} (${pct}%)</div>`;
  $('cMoney').textContent=d.money.toLocaleString()+'円';
  renderCLog();
}

// ===== COUNTRY LOG =====
const TOKNAMES={pop:'人口',farm:'農業',fish:'漁業',livestock:'畜産',trade:'貿易',money:'資金'};
const TOKICONS={pop:'👥',farm:'🌾',fish:'🐟',livestock:'🐄',trade:'🚢',money:'💴'};

function addCLog(country, entry){
  if(!G.countryLogs[country]) G.countryLogs[country]=[];
  G.countryLogs[country].unshift({...entry, turn:G.turn, time:new Date().toLocaleTimeString('ja-JP')});
}

function renderCLog(){
  const el=$('cLogInner');
  if(!el)return;
  const logs=(G.countryLogs[cRole]||[]);
  if(!logs.length){
    el.innerHTML=`<div class="clog-empty">まだ記録はありません。<br>イベントカードや交渉でトークン・資金が変動すると<br>ここに履歴が残ります。</div>`;
    return;
  }
  el.innerHTML=logs.map(e=>{
    const chips=e.changes.map(c=>{
      const pos=c.delta>0;
      const label=`${TOKICONS[c.key]||''}${TOKNAMES[c.key]||c.key} ${pos?'+':''}${c.key==='money'?c.delta.toLocaleString()+'円':c.delta}`;
      return `<span class="ce-chip ${pos?'pos':'neg'}">${label}</span>`;
    }).join('');
    const typeLabel={plus:'＋イベント',minus:'－イベント',trade:'国間取引',manual:'手動更新'}[e.type]||'変動';
    const typeCls={plus:'plus',minus:'minus',trade:'trade',manual:'manual'}[e.type]||'manual';
    return `<div class="clog-entry ev-${e.type}">
      <div class="ce-top">
        <span class="ce-turn">ターン ${e.turn}　${e.time}</span>
        <span class="ce-type ${typeCls}">${typeLabel}</span>
      </div>
      <div class="ce-title">${e.title}</div>
      <div class="ce-chips">${chips}</div>
    </div>`;
  }).join('');
}

function clearCLog(){
  if(G.countryLogs[cRole]) G.countryLogs[cRole]=[];
  renderCLog();
}

function cAdj(key,delta){
  const d=G.countries[cRole];
  const before=d[key];
  d[key]=Math.max(0,d[key]+delta);
  const actual=d[key]-before;
  if(actual!==0){
    addCLog(cRole,{type:'manual',title:'手動更新',changes:[{key,delta:actual}]});
  }
  renderCountry();
}
function cAdjMoney(delta){
  const d=G.countries[cRole];
  const before=d.money;
  d.money=Math.max(0,d.money+delta);
  const actual=d.money-before;
  if(actual!==0){
    addCLog(cRole,{type:'manual',title:'手動更新',changes:[{key:'money',delta:actual}]});
  }
  renderCountry();
}

// ===== WB =====
