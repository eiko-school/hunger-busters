<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hunger Busters</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0f1117;--surface:#181c27;--card:#1e2333;--border:#2a3050;
  --accent:#f5a623;--red:#e05c5c;--green:#4caf7d;--purple:#9b6dff;
  --text:#e8eaf6;--muted:#7a82a0;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans JP',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.hidden{display:none!important;}

/* SHARED BUTTONS */
.btn{border:none;cursor:pointer;font-family:'Noto Sans JP',sans-serif;font-weight:700;border-radius:8px;transition:all .2s;letter-spacing:1px;}
.btn-gold{background:var(--accent);color:#000;padding:12px 28px;font-size:1rem;}
.btn-gold:hover{opacity:.85;transform:translateY(-1px);}
.btn-ghost{background:var(--card);border:1px solid var(--border);color:var(--text);padding:7px 16px;font-size:.8rem;}
.btn-ghost:hover{border-color:var(--accent);}
.btn-purple{background:rgba(155,109,255,.12);border:1px solid var(--purple);color:var(--purple);padding:9px 18px;font-size:.85rem;font-weight:700;border-radius:8px;cursor:pointer;transition:all .2s;}
.btn-purple:hover{background:rgba(155,109,255,.25);}
.btn-sm{background:var(--surface);border:1px solid var(--border);color:var(--muted);padding:5px 12px;font-size:.74rem;border-radius:6px;cursor:pointer;}
.btn-sm:hover{color:var(--text);border-color:var(--accent);}
.adj{display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:5px;border:1px solid var(--border);background:var(--surface);color:var(--text);cursor:pointer;font-size:.9rem;transition:background .15s;}
.adj:hover{background:var(--border);}
.adj.p{color:var(--green);}.adj.m{color:var(--red);}

/* ===== LOBBY ===== */
#lobbyScreen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:40px 20px;background:radial-gradient(ellipse at 50% 0%,#1a0e00,var(--bg) 70%);}
h1.logo{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;letter-spacing:4px;color:var(--accent);text-shadow:0 0 30px rgba(245,166,35,.4);}
h1.logo span{color:#fff;}
.lobby-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:36px 40px;width:100%;max-width:500px;margin-top:28px;}
.lobby-box h2{font-size:.9rem;color:var(--muted);margin-bottom:22px;letter-spacing:1px;text-transform:uppercase;}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.field label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;}
.field select{background:var(--card);border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-family:'Noto Sans JP',sans-serif;font-size:.9rem;}
hr.div{border:none;border-top:1px solid var(--border);margin:18px 0;}

/* ===== ROLE SELECT ===== */
#roleScreen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:40px 20px;background:radial-gradient(ellipse at 50% 0%,#0a0a1a,var(--bg) 70%);}
.role-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:22px 0;width:100%;max-width:460px;}
.role-card{background:var(--card);border:2px solid var(--border);border-radius:12px;padding:20px 14px;cursor:pointer;transition:all .2s;text-align:center;}
.role-card:hover{border-color:var(--accent);transform:translateY(-2px);}
.role-card.wb{border-color:rgba(155,109,255,.35);}
.role-card.wb:hover{border-color:var(--purple);}
.role-card .ico{font-size:2rem;margin-bottom:8px;}
.role-card .rn{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;}
.role-card.wb .rn{color:var(--purple);}
.role-card .rd{font-size:.7rem;color:var(--muted);margin-top:4px;}

/* ===== COUNTRY SCREEN ===== */
#countryScreen header{background:linear-gradient(135deg,#1a0a00,#2d1400 60%,#0f1117);border-bottom:2px solid var(--accent);padding:13px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.h-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;color:var(--accent);}
.h-title span{color:#fff;}
.turn-badge{background:var(--accent);color:#000;font-weight:900;font-size:.78rem;padding:5px 13px;border-radius:4px;}
.turn-badge.wb{background:var(--purple);color:#fff;}
.c-main{padding:18px 22px;max-width:560px;margin:0 auto;}

.c-hero{background:linear-gradient(135deg,var(--card),var(--surface));border:1px solid var(--border);border-radius:14px;padding:18px 22px;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;}
.c-hero .cn{font-family:'Bebas Neue',sans-serif;font-size:2.4rem;letter-spacing:3px;}
.pill{padding:6px 15px;border-radius:20px;font-weight:700;font-size:.78rem;}
.pill.safe{background:rgba(76,175,125,.15);color:var(--green);border:1px solid rgba(76,175,125,.3);}
.pill.danger{background:rgba(224,92,92,.15);color:var(--red);border:1px solid rgba(224,92,92,.4);animation:blink 1.2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.5}}

.tok-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:15px 18px;margin-bottom:14px;}
.tok-card h3{font-family:'Bebas Neue',sans-serif;letter-spacing:2px;color:var(--muted);font-size:.88rem;margin-bottom:12px;}
.tok-row{display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.tok-row:last-child{border-bottom:none;}
.t-ico{font-size:1rem;width:22px;text-align:center;}
.t-lbl{font-size:.76rem;color:var(--muted);width:56px;}
.t-val{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:1px;min-width:36px;text-align:right;}
.t-val.pop{color:#fff}.t-val.farm{color:#7ec850}.t-val.fish{color:#4ab3e8}.t-val.live{color:#e8a14a}.t-val.trade{color:#c47ae8}
.t-adjs{display:flex;gap:4px;margin-left:auto;}

.food-bar{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:14px;}
.fb-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.fb-row .lbl{font-size:.76rem;color:var(--muted);}
.fb-row .val{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:1px;}
.fb-row .val.safe{color:var(--green);}.fb-row .val.danger{color:var(--red);}
.prog-wrap{background:var(--surface);border-radius:6px;height:10px;overflow:hidden;}
.prog-fill{height:100%;border-radius:6px;transition:width .4s;}
.prog-fill.safe{background:linear-gradient(90deg,var(--green),#a8e063);}
.prog-fill.danger{background:linear-gradient(90deg,var(--red),#ff8080);}

.money-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 18px;display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.money-card .lbl{font-size:.76rem;color:var(--muted);margin-bottom:3px;}
.money-card .val{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--accent);letter-spacing:1px;}
.money-adjs{display:flex;gap:5px;flex-wrap:wrap;justify-content:flex-end;max-width:210px;}
.money-adjs .adj{width:auto;padding:0 10px;font-size:.7rem;height:26px;}

.hint-box{background:rgba(245,166,35,.06);border:1px solid rgba(245,166,35,.2);border-radius:10px;padding:14px 18px;font-size:.8rem;color:var(--muted);line-height:1.65;}
.hint-box strong{color:var(--accent);}

/* COUNTRY LOG */
.clog-box{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:15px 18px;margin-bottom:14px;}
.clog-box .clog-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.clog-box .clog-title{font-family:'Bebas Neue',sans-serif;letter-spacing:2px;color:var(--muted);font-size:.9rem;display:flex;align-items:center;gap:6px;}
.clog-inner{max-height:260px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;}
.clog-inner::-webkit-scrollbar{width:4px}.clog-inner::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.clog-entry{background:var(--surface);border-radius:8px;padding:9px 12px;border-left:3px solid var(--border);}
.clog-entry.ev-plus{border-left-color:var(--green);}
.clog-entry.ev-minus{border-left-color:var(--red);}
.clog-entry.ev-trade{border-left-color:#4ab3e8;}
.clog-entry.ev-manual{border-left-color:var(--accent);}
.clog-entry .ce-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.clog-entry .ce-turn{font-size:.66rem;color:var(--muted);}
.clog-entry .ce-type{font-size:.66rem;font-weight:700;padding:2px 7px;border-radius:4px;}
.ce-type.plus{background:rgba(76,175,125,.15);color:var(--green);}
.ce-type.minus{background:rgba(224,92,92,.15);color:var(--red);}
.ce-type.trade{background:rgba(74,179,232,.15);color:#4ab3e8;}
.ce-type.manual{background:rgba(245,166,35,.15);color:var(--accent);}
.clog-entry .ce-title{font-size:.78rem;font-weight:700;color:var(--text);margin-bottom:5px;}
.clog-entry .ce-chips{display:flex;flex-wrap:wrap;gap:4px;}
.ce-chip{font-size:.72rem;font-weight:700;padding:3px 8px;border-radius:5px;background:var(--card);}
.ce-chip.pos{color:var(--green);border:1px solid rgba(76,175,125,.3);}
.ce-chip.neg{color:var(--red);border:1px solid rgba(224,92,92,.3);}
.ce-chip.neu{color:var(--muted);border:1px solid var(--border);}
.clog-empty{text-align:center;padding:20px;color:var(--muted);font-size:.78rem;line-height:1.7;}

/* REFLECTION PROMPT */
.reflect-box{background:rgba(155,109,255,.06);border:1px solid rgba(155,109,255,.2);border-radius:10px;padding:14px 18px;margin-bottom:14px;font-size:.8rem;color:var(--muted);line-height:1.7;}
.reflect-box strong{color:var(--purple);}

/* ===== WB SCREEN ===== */
#wbScreen header{background:linear-gradient(135deg,#0a0017,#180030 60%,#0f1117);border-bottom:2px solid var(--purple);padding:13px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
#wbScreen header .h-title{color:var(--purple);}
.wb-main{padding:18px 22px;max-width:960px;margin:0 auto;}

.hunger-banner{background:linear-gradient(90deg,#3a0000,#1a0000);border:1px solid var(--red);border-radius:10px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:flex-start;gap:14px;}
.hunger-banner .h-ico{font-size:1.5rem;margin-top:2px;}
.hunger-banner .h-t{font-weight:900;color:#ff8080;font-size:.92rem;margin-bottom:4px;}
.hunger-banner .h-l{font-size:.8rem;color:#ffaaaa;line-height:1.7;}
.safe-banner{background:rgba(76,175,125,.08);border:1px solid rgba(76,175,125,.3);border-radius:10px;padding:12px 18px;margin-bottom:18px;font-size:.83rem;color:var(--green);font-weight:700;}

.sec-t{font-family:'Bebas Neue',sans-serif;letter-spacing:2px;color:var(--muted);font-size:.92rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec-t::after{content:'';flex:1;height:1px;background:var(--border);}

.ov-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:13px;margin-bottom:22px;}
.ov-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .2s;}
.ov-card.hungry{border-color:var(--red);}
.ov-card.wb-c{border-color:rgba(155,109,255,.35);}
.ov-head{background:var(--surface);padding:9px 13px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);}
.ov-n{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:2px;}
.ov-n.hungry{color:var(--red);}.ov-n.wb-c{color:var(--purple);}
.ov-pill{font-size:.66rem;padding:3px 9px;border-radius:10px;font-weight:700;}
.ov-pill.safe{background:rgba(76,175,125,.15);color:var(--green);border:1px solid rgba(76,175,125,.25);}
.ov-pill.danger{background:rgba(224,92,92,.15);color:var(--red);border:1px solid rgba(224,92,92,.3);}
.ov-body{padding:9px 13px;}
.ov-tr{display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:.76rem;}
.ov-tr:last-child{border-bottom:none;}
.ov-tr .ico{width:17px;text-align:center;}
.ov-tr .lbl{color:var(--muted);width:52px;}
.ov-tr .vl{font-family:'Bebas Neue',sans-serif;font-size:.93rem;min-width:28px;text-align:right;}
.ov-tr .vl.pop{color:#fff}.ov-tr .vl.farm{color:#7ec850}.ov-tr .vl.fish{color:#4ab3e8}.ov-tr .vl.live{color:#e8a14a}.ov-tr .vl.trade{color:#c47ae8}
.ov-tr .oa{display:flex;gap:3px;margin-left:auto;}
.ov-tr .oa .adj{width:21px;height:21px;font-size:.78rem;}
.ov-money{display:flex;justify-content:space-between;align-items:center;padding-top:7px;margin-top:3px;border-top:1px solid var(--border);font-size:.76rem;}
.ov-money .lbl{color:var(--muted);}
.ov-money .vl{font-family:'Bebas Neue',sans-serif;color:var(--accent);font-size:.92rem;}
.ov-money .oma{display:flex;gap:3px;}
.ov-money .oma .adj{width:auto;padding:0 7px;font-size:.66rem;height:21px;}
.ov-food{display:flex;justify-content:space-between;align-items:center;background:rgba(255,255,255,.03);border-radius:5px;padding:5px 8px;margin-top:7px;font-size:.73rem;}
.ov-food .lbl{color:var(--muted);}
.ov-food .vl{font-family:'Bebas Neue',sans-serif;font-size:.88rem;}
.ov-food .vl.safe{color:var(--green);}.ov-food .vl.danger{color:var(--red);}

/* EVENT PANEL */
.ev-panel{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:18px;}
.ev-tabs{display:flex;gap:8px;margin-bottom:12px;}
.ev-tab{padding:7px 16px;border-radius:6px;border:1px solid var(--border);background:var(--card);color:var(--muted);cursor:pointer;font-size:.8rem;font-weight:700;transition:all .2s;}
.ev-tab.active.plus{background:rgba(76,175,125,.15);border-color:var(--green);color:var(--green);}
.ev-tab.active.minus{background:rgba(224,92,92,.15);border-color:var(--red);color:var(--red);}
.ev-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(215px,1fr));gap:8px;max-height:350px;overflow-y:auto;padding-right:3px;}
.ev-list::-webkit-scrollbar{width:4px}.ev-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.ev-item{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:9px 11px;cursor:pointer;transition:all .2s;}
.ev-item:hover{transform:translateY(-1px);}
.ev-item.plus:hover{border-color:var(--green);}.ev-item.minus:hover{border-color:var(--red);}
.ev-num{font-family:'Bebas Neue',sans-serif;font-size:.72rem;color:var(--muted);}
.ev-title{font-weight:700;font-size:.8rem;margin:3px 0;}
.ev-eff{font-size:.68rem;font-weight:700;}
.ev-item.plus .ev-eff{color:var(--green);}.ev-item.minus .ev-eff{color:var(--red);}
.ev-desc{font-size:.66rem;color:var(--muted);margin-top:3px;line-height:1.4;}

/* ACTIONS ROW */
.act-row{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:18px;}

/* LOG */
.log-box{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:15px 18px;}
.log-inner{max-height:190px;overflow-y:auto;font-size:.74rem;color:var(--muted);line-height:1.9;}
.log-inner::-webkit-scrollbar{width:4px}.log-inner::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.le .tt{color:var(--accent);font-weight:700;margin-right:5px;}
.le .et{font-weight:700;}
.le.pl .et{color:var(--green);}.le.mi .et{color:var(--red);}.le.sy .et{color:var(--purple);}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:300;display:none;align-items:center;justify-content:center;padding:20px;}
.overlay.open{display:flex;}
.modal{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px;width:100%;max-width:450px;position:relative;}
.m-close{position:absolute;top:13px;right:13px;background:var(--surface);border:1px solid var(--border);color:var(--muted);width:27px;height:27px;border-radius:50%;cursor:pointer;font-size:.95rem;display:flex;align-items:center;justify-content:center;}
.m-close:hover{color:var(--text);}
.modal h3{font-family:'Bebas Neue',sans-serif;font-size:1.35rem;letter-spacing:2px;margin-bottom:4px;}
.modal h3.plus{color:var(--green);}.modal h3.minus{color:var(--red);}
.modal .eff{font-size:.8rem;color:var(--accent);font-weight:700;margin-bottom:7px;}
.modal .dsc{font-size:.76rem;color:var(--muted);line-height:1.5;margin-bottom:16px;}
.modal .mlbl{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:7px;}
.chk-list{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px;}
.chk{display:flex;align-items:center;gap:6px;background:var(--surface);border:1px solid var(--border);padding:6px 12px;border-radius:7px;cursor:pointer;font-size:.8rem;user-select:none;transition:all .15s;}
.chk input{accent-color:var(--accent);cursor:pointer;}
.chk:hover{border-color:var(--accent);}
.m-foot{display:flex;gap:9px;justify-content:flex-end;}
.tr-row{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.tr-row label{font-size:.74rem;color:var(--muted);width:52px;}
.tr-row select,.tr-row input{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:7px 10px;border-radius:7px;font-family:'Noto Sans JP',sans-serif;font-size:.83rem;flex:1;}
</style>
</head>
<body>

<!-- LOBBY -->
<div id="lobbyScreen">
  <h1 class="logo">HUNGER <span>BUSTERS</span></h1>
  <p style="color:var(--muted);font-size:.83rem;margin-top:6px;letter-spacing:2px">食料安全保障シミュレーションゲーム</p>
  <div class="lobby-box">
    <h2>ゲームセットアップ（先生用）</h2>
    <div class="field"><label>国 1（2人担当）</label>
      <select id="sel1"><option>日本</option><option>アメリカ</option><option>インド</option><option>カナダ</option><option>イギリス</option><option>エジプト</option><option>アルゼンチン</option><option>ブラジル</option><option>オーストラリア</option><option>ベトナム</option></select></div>
    <div class="field"><label>国 2（2人担当）</label>
      <select id="sel2"><option>アメリカ</option><option>日本</option><option>インド</option><option>カナダ</option><option>イギリス</option><option>エジプト</option><option>アルゼンチン</option><option>ブラジル</option><option>オーストラリア</option><option>ベトナム</option></select></div>
    <div class="field"><label>国 3（2人担当）</label>
      <select id="sel3"><option>ブラジル</option><option>日本</option><option>アメリカ</option><option>インド</option><option>カナダ</option><option>イギリス</option><option>エジプト</option><option>アルゼンチン</option><option>オーストラリア</option><option>ベトナム</option></select></div>
    <hr class="div">
    <button class="btn btn-gold" style="width:100%" onclick="setupGame()">▶ ゲーム開始</button>
  </div>
</div>

<!-- ROLE SELECT -->
<div id="roleScreen" class="hidden">
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:40px 20px;background:radial-gradient(ellipse at 50% 0%,#0a0a1a,var(--bg) 70%)">
    <h1 class="logo">HUNGER <span>BUSTERS</span></h1>
    <p style="color:var(--muted);font-size:.83rem;margin-top:6px;letter-spacing:2px">あなたの役割を選んでください</p>
    <p style="color:var(--muted);font-size:.73rem;margin-top:4px;margin-bottom:24px">※ 各グループのパソコンで担当する役割を選択します</p>
    <div class="role-grid" id="roleGrid"></div>
  </div>
</div>

<!-- COUNTRY SCREEN -->
<div id="countryScreen" class="hidden">
  <header>
    <div class="h-title">HUNGER <span>BUSTERS</span></div>
    <div style="display:flex;align-items:center;gap:9px">
      <div class="turn-badge" id="cTurn">ターン 1</div>
      <button class="btn btn-ghost" onclick="backToRole()">← 役割選択</button>
    </div>
  </header>
  <div class="c-main">
    <div class="c-hero">
