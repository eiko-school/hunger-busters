function wAdj(n,k,d){const o=gd(n);o[k]=Math.max(0,o[k]+d);renderWB();}
function wAdjM(n,d){const o=gd(n);o.money=Math.max(0,o.money+d);renderWB();}

// ===== EVENTS =====
function renderEvList(){
  const l=$('evList');l.innerHTML='';
  (G.evTab==='plus'?PLUS_EV:MINUS_EV).forEach(ev=>{
    const d=document.createElement('div');
    d.className=`ev-item ${G.evTab}`;
    d.innerHTML=`<div class="ev-num">No.${ev.num}</div>
      <div class="ev-title">${ev.title}</div>
      <div class="ev-eff">${ev.eff}</div>
      <div class="ev-desc">${ev.desc}</div>`;
    d.onclick=()=>openEvM(ev,G.evTab);
    l.appendChild(d);
  });
}

function switchTab(tab){
  G.evTab=tab;
  $('tabPlus').className='ev-tab'+(tab==='plus'?' active plus':' plus');
  $('tabMinus').className='ev-tab'+(tab==='minus'?' active minus':' minus');
  renderEvList();
}

function openEvM(ev,type){
  G.curEv={ev,type};
  $('emTitle').textContent=ev.title;$('emTitle').className=type;
  $('emEff').textContent=ev.eff;$('emDesc').textContent=ev.desc;
  const c=$('emChecks');c.innerHTML='';
  [...G.sel,'世界銀行'].forEach(n=>{
    const l=document.createElement('label');l.className='chk';
    l.innerHTML=`<input type="checkbox" value="${n}" ${n!=='世界銀行'?'checked':''}> ${n}`;
    c.appendChild(l);
  });
  $('evModal').classList.add('open');
}
function closeEvM(){$('evModal').classList.remove('open');G.curEv=null;}

function applyEv(){
  if(!G.curEv)return;
  const {ev,type}=G.curEv;
  const ch=[...$('emChecks').querySelectorAll('input:checked')].map(i=>i.value);
  if(!ch.length){alert('少なくとも1か国を選択してください。');return;}

  const NAMES={pop:'人口',farm:'農業',fish:'漁業',livestock:'畜産',trade:'貿易'};
  const ICONS={pop:'👥',farm:'🌾',fish:'🐟',livestock:'🐄',trade:'🚢'};
  const announceLines=[];

  ch.forEach(name=>{
    const d=gd(name);
    const changes=[];
    Object.entries(ev.tok||{}).forEach(([k,v])=>{
      if(k==='anyFood'){
        const fs=['farm','fish','livestock'],p=Math.floor(Math.abs(v)/3);
        fs.forEach(f=>{
          const before=d[f];
          d[f]=Math.max(0,d[f]+(v>0?p:-p));
          const delta=d[f]-before;
          if(delta!==0)changes.push(`${ICONS[f]}${NAMES[f]} ${delta>0?'+':''}${delta}`);
        });
      } else if(v==='half'){
        const before=d[k];
        d[k]=Math.floor(d[k]/2);
        changes.push(`${ICONS[k]||''}${NAMES[k]||k} ${before}→${d[k]}（半分）`);
      } else if(v==='zero'){
        changes.push(`${ICONS[k]||''}${NAMES[k]||k} →0（全没収）`);
        d[k]=0;
      } else {
        d[k]=Math.max(0,(d[k]||0)+v);
        changes.push(`${ICONS[k]||''}${NAMES[k]||k} ${v>0?'+':''}${v}`);
      }
    });
    if(ev.money){
      d.money=Math.max(0,d.money+ev.money);
      changes.push(`💴資金 ${ev.money>0?'+':''}${ev.money.toLocaleString()}円`);
    }
    if(changes.length)announceLines.push({name,changes});
    // 各国ログに記録
    if(name!=='世界銀行' && G.countryLogs[name]!==undefined){
      const cChanges=[];
      Object.entries(ev.tok||{}).forEach(([k,v])=>{
        if(k==='anyFood'){
          const p=Math.floor(Math.abs(v)/3);
          ['farm','fish','livestock'].forEach(f=>cChanges.push({key:f,delta:v>0?p:-p}));
        } else if(v==='half'){
          const cur=G.countries[name][k];
          cChanges.push({key:k,delta:cur-cur*2});// show as negative half
        } else if(v==='zero'){
          cChanges.push({key:k,delta:0,label:'全没収'});
        } else {
          cChanges.push({key:k,delta:v});
        }
      });
      if(ev.money) cChanges.push({key:'money',delta:ev.money});
      if(cChanges.length) addCLog(name,{type,title:`No.${ev.num} ${ev.title}`,changes:cChanges});
    }
  });

  // build announce modal content
  const isPlus=type==='plus';
  const color=isPlus?'var(--green)':'var(--red)';
  let html=`
    <div style="background:var(--surface);border:1px solid ${color};border-radius:10px;padding:14px 16px;margin-bottom:14px">
      <div style="font-size:.7rem;color:var(--muted);letter-spacing:1px;margin-bottom:4px">イベントNo.${ev.num} / ${isPlus?'＋プラス':'－マイナス'}</div>
      <div style="font-weight:700;font-size:1rem;color:${color};margin-bottom:4px">${ev.title}</div>
      <div style="font-size:.75rem;color:var(--muted)">${ev.eff}</div>
    </div>`;

  if(announceLines.length){
    html+=`<div style="display:flex;flex-direction:column;gap:8px">`;
    announceLines.forEach(({name,changes})=>{
      html+=`<div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:11px 14px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;margin-bottom:7px">${name}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          ${changes.map(c=>`<span style="background:var(--surface);border:1px solid ${color};color:${color};padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:700">${c}</span>`).join('')}
        </div>
      </div>`;
    });
    html+=`</div>`;
  } else {
    html+=`<div style="color:var(--muted);font-size:.8rem;text-align:center;padding:10px">トークン・資金の変動はありません</div>`;
  }

  $('announceContent').innerHTML=html;
  addLog('イベント適用',`[${isPlus?'＋':'－'}] No.${ev.num}「${ev.title}」→ ${ch.join(', ')}`,type);
  closeEvM();
  $('announceModal').classList.add('open');
  renderWB();
}

